<?xml version="1.0"?>
<ruleset name="My custom PHPMD rule set"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0
                     http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="
                     http://pmd.sf.net/ruleset_xml_schema.xsd">
    <description>
        My custom rule set that checks code
    </description>

    <exclude-pattern>src/Shared/Infrastructure/Migration/**/*.php</exclude-pattern>
    <exclude-pattern>test/**/*Test.php</exclude-pattern>

    <rule ref="rulesets/cleancode.xml">
        <exclude name="StaticAccess" />
    </rule>

    <rule ref="rulesets/codesize.xml">
        <exclude name="TooManyPublicMethods" />
    </rule>

    <rule ref="rulesets/codesize.xml/TooManyPublicMethods">
        <properties>
            <property name="ignorepattern">
                <value>(^(__|set|get|toString|toMemento|fromMemento))i</value>
            </property>
        </properties>
    </rule>

    <rule ref="rulesets/controversial.xml" />
    <rule ref="rulesets/unusedcode.xml" />

    <rule ref="rulesets/naming.xml">
        <exclude name="ShortVariable" />
        <exclude name="LongVariable" />
        <exclude name="ShortMethodName" />
        <exclude name="ShortClassName" />
        <exclude name="LongClassName" />
    </rule>

    <rule ref="rulesets/naming.xml/LongClassName">
        <properties>
            <property name="maximum">
                <value>60</value>
            </property>
        </properties>
    </rule>

    <rule ref="rulesets/naming.xml/ShortClassName">
        <properties>
            <property name="minimum">
                <value>2</value>
            </property>
        </properties>
    </rule>

    <rule ref="rulesets/naming.xml/ShortVariable">
        <properties>
            <property name="minimum">
                <value>2</value>
            </property>
        </properties>
    </rule>

    <rule ref="rulesets/naming.xml/ShortMethodName">
        <properties>
            <property name="minimum">
                <value>2</value>
            </property>
        </properties>
    </rule>

    <rule ref="rulesets/naming.xml/LongVariable">
        <properties>
            <property name="maximum">
                <value>30</value>
            </property>
        </properties>
    </rule>
</ruleset>
